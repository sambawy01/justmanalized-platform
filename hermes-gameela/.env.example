# Railway → Service → Variables. (Do NOT commit real values.)

# LLM = Ollama Cloud, OpenAI-compatible endpoint (verified: returns tool_calls).
OPENAI_API_KEY=        # your Ollama Cloud API key (OLLAMA_API_KEY value)
CUSTOM_BASE_URL=https://ollama.com/v1

# Telegram (long-polling — no public port needed)
TELEGRAM_BOT_TOKEN=    # the @GameelaAi_bot token
TELEGRAM_ALLOWED_USERS=  # Manal's numeric Telegram user id (lock the bot to her)

# Your existing shop backend (skills call these over HTTPS)
SHOP_API_BASE=https://shop.justmanalized.com
SHOP_ADMIN_KEY=        # ADMIN_TOKEN — lets the skills call /api/admin/*
