# Owner admin page (/admin?key=<token>) + Basic auth. Generate with:
#   openssl rand -hex 32
ADMIN_TOKEN=

# Ollama Cloud (AI concierge). Leave OLLAMA_API_KEY empty in local dev
# to use a local ollama at http://localhost:11434.
OLLAMA_API_KEY=
OLLAMA_MODEL=deepseek-v4-flash:cloud

# Order/notification emails (Resend, https://resend.com).
# When RESEND_API_KEY is unset, emails are logged and no-op'd.
RESEND_API_KEY=
NOTIFY_EMAIL=hello@justmanalized.com

# Vercel Cron auth for /api/cron/* (daily brief, weekly/monthly reports, etc.).
# When set on the Vercel project, Vercel sends "Authorization: Bearer <secret>"
# with every cron invocation; the routes reject everything else. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# Telegram owner assistant (/api/telegram/webhook). Create the bot with
# @BotFather (/newbot); without a token the webhook route answers 501 and the
# daily-brief Telegram push no-ops.
TELEGRAM_BOT_TOKEN=

# Webhook authenticity secret: Telegram echoes it back in the
# X-Telegram-Bot-Api-Secret-Token header on every update; the route fails
# closed without a match. Generate with:
#   openssl rand -hex 32
# then run scripts/setup-telegram.mjs to register the webhook.
TELEGRAM_WEBHOOK_SECRET=
